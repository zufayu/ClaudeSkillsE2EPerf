# MI355X Platform Configuration
# Runner IS the GPU node — uses podman, not docker.
#
# All vars use `: ${VAR:=...}` (set-if-unset) so workflow steps can override.

: ${PLATFORM:=mi355x}
: ${EXEC_MODE:=podman}
: ${REPO:=/shared/amdgpu/home/zufa_yu_qle/ClaudeSkillsE2EPerf}
: ${MODEL_MXFP4:=/shared/data/amd_int/models/DeepSeek-R1-0528-MXFP4-MTP-MoEFP4}
: ${DEFAULT_CONTAINER:=zufa_atom}
: ${ATOM2_CONTAINER:=zufa_atom2}
: ${CI_USER_NAME:="MI355X CI"}
: ${CI_USER_EMAIL:=ci@github.com}
export PLATFORM EXEC_MODE REPO MODEL_MXFP4 DEFAULT_CONTAINER ATOM2_CONTAINER CI_USER_NAME CI_USER_EMAIL
