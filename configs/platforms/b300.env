# B300 Platform Configuration
# Runner IS the GPU node — no SSH needed.
#
# All vars use `: ${VAR:=...}` (set-if-unset) so workflow steps can
# override (e.g. `export REPO="$GITHUB_WORKSPACE"` before sourcing).

: ${PLATFORM:=b300}
: ${EXEC_MODE:=docker}
: ${REPO:=/home/zufa/ClaudeSkillsE2EPerf}
: ${MODEL_FP4:=/models/DeepSeek-R1-0528-NVFP4-v2}
: ${DEFAULT_CONTAINER:=zufa_sglang}
: ${SGLANG_CONTAINER:=zufa_sglang}
: ${CI_USER_NAME:="B300 CI"}
: ${CI_USER_EMAIL:=ci@github.com}
export PLATFORM EXEC_MODE REPO MODEL_FP4 DEFAULT_CONTAINER SGLANG_CONTAINER CI_USER_NAME CI_USER_EMAIL
