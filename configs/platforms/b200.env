# All vars use `: ${VAR:=...}` (set-if-unset) so workflow steps can override.

: ${PLATFORM:=b200}
: ${EXEC_MODE:=ssh+docker}
: ${REPO:=/home/ubuntu/zufa/ClaudeSkillsE2EPerf}
: ${SFS:=/SFS-aGqda6ct}
: ${MODEL_FP4:=/SFS-aGqda6ct/models/DeepSeek-R1-0528-NVFP4-v2}
: ${MODEL_FP8:=/SFS-aGqda6ct/models/models--DeepSeek-R1-0528}
: ${DEFAULT_CONTAINER:=zufa_trt}
: ${SGLANG_CONTAINER:=zufa_sglang}
: ${CI_USER_NAME:="B200 CI"}
: ${CI_USER_EMAIL:=ci@github.com}
export PLATFORM EXEC_MODE REPO SFS MODEL_FP4 MODEL_FP8 DEFAULT_CONTAINER SGLANG_CONTAINER CI_USER_NAME CI_USER_EMAIL
